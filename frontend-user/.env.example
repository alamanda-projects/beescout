# =======================
# Project : BeeScout — Frontend User
# File    : frontend-user/.env.example
#
# SETUP:
#   cp .env.example .env.local   (for local development)
#   In production, set via docker-compose environment section
# =======================

# Base URL for API calls (browser-side)
#   Production (via nginx):      /api
#   Development (direct to BE):  http://localhost:8888
NEXT_PUBLIC_API_BASE=http://localhost:8888

# Internal API URL for server-side rendering (SSR) calls
# Must be reachable from inside the Docker network
#   Production: http://backend:8888
#   Development: http://localhost:8888
API_INTERNAL_BASE=http://localhost:8888
