# ══════════════════════════════════════════════════════════════════════════════
# [API] — Backend URL
#
# Development: set to the backend's direct URL or use Next.js proxy
# Production : leave as /api — Nginx proxies /api/* → backend container
# ══════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_API_BASE=http://localhost:8888
