# =======================
# Project : BeeScout — Root Environment Template
# File    : .env.example
# Function: Single source of truth for all service configurations
#
# SETUP:
#   cp .env.example .env
#   Edit .env with your actual values
#   Never commit .env to version control
#
# COMPONENTS:
#   [DOMAIN]    — Nginx routing (user & admin subdomains)
#   [NGINX]     — Rate limiting tuning
#   [BACKEND]   — MongoDB credentials, JWT secrets, app info
#   [SECURITY]  — Cookie & CORS settings
# =======================


# ══════════════════════════════════════════════════════════════════════════════
# [DOMAIN] — Subdomain routing
# Set these to the subdomains you own. Nginx uses these at startup.
#
# Examples:
#   Local dev (add to /etc/hosts):    app.localhost   admin.localhost
#   Production:                       app.yourcompany.com  admin.yourcompany.com
# ══════════════════════════════════════════════════════════════════════════════

BEESCOUT_USER_DOMAIN=app.localhost
BEESCOUT_ADMIN_DOMAIN=admin.localhost


# ══════════════════════════════════════════════════════════════════════════════
# [NGINX] — Rate limiting
# BEESCOUT_RATE_LOGIN  : max login attempts per minute per IP
# BEESCOUT_RATE_API    : max API requests per second per IP
# ══════════════════════════════════════════════════════════════════════════════

BEESCOUT_RATE_LOGIN=10
BEESCOUT_RATE_API=30


# ══════════════════════════════════════════════════════════════════════════════
# [DATABASE] — MongoDB credentials
# Used by: db container (build args) + backend container (connection)
# ══════════════════════════════════════════════════════════════════════════════

MONGODB_USER=admin
MONGODB_PASS=changeme_strong_password_here
MONGODB_PORT=27017
MONGODB_DB=dgrdb
MONGODB_COLLECTION_DGR=dgr
MONGODB_COLLECTION_USR=dgrusr


# ══════════════════════════════════════════════════════════════════════════════
# [BACKEND — JWT & SA Keys]
# Generate strong secrets: openssl rand -hex 32
#
# TKN_*  : Short-lived tokens for regular user sessions
# SA_*   : Long-lived tokens for service account (machine-to-machine) access
# ══════════════════════════════════════════════════════════════════════════════

# User session tokens
TKN_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
TKN_SECRET_TOKEN=changeme_generate_with_openssl_rand_hex_32
TKN_ALGORITHM=HS256
TKN_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Service account keys
SA_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
SA_SECRET_TOKEN=changeme_generate_with_openssl_rand_hex_32
SA_ALGORITHM=HS256
SA_ACCESS_TOKEN_EXPIRE_DAYS=365


# ══════════════════════════════════════════════════════════════════════════════
# [SECURITY] — CORS & Cookie settings
#
# ALLOWED_ORIGINS: Comma-separated list of origins allowed to call the API
#   Production  : https://app.yourcompany.com,https://admin.yourcompany.com
#   Development : http://localhost:3000,http://localhost:3001
#
# COOKIE_SECURE: Set to "true" in production (requires HTTPS).
#   Set to "false" only for local development without HTTPS.
# ══════════════════════════════════════════════════════════════════════════════

ALLOWED_ORIGINS=http://app.localhost,http://admin.localhost
COOKIE_SECURE=true


# ══════════════════════════════════════════════════════════════════════════════
# [BACKEND — Application Info]
# Displayed in API responses and welcome page
# ══════════════════════════════════════════════════════════════════════════════

APP_TITLE=BeeScout Repository
APP_DESCRIPTION=Data Contract Management System
APP_SUMMARY=Sistem pengelolaan Data Contract
APP_VERSION=0.1.0
APP_CONTACT_NAME=Your Name or Team
APP_CONTACT_URL=https://your-org.example.com
APP_CONTACT_EMAIL=your@email.com
APP_LICENSE_INFO_NAME=AGPL v3.0
APP_LICENSE_INFO_URL=https://www.gnu.org/licenses/agpl-3.0.txt


# ══════════════════════════════════════════════════════════════════════════════
# [BACKEND — Error Messages]
# These are customizable response messages. Safe to leave as defaults.
# ══════════════════════════════════════════════════════════════════════════════

DC_404=Data Contract not found!
DC_412=Data Contract invalid!
USR_401_UNAUTH=Incorrect username or password!
USR_401_INACT=User inactive!
USR_401_CNVC=Could not validate credentials!
USR_403=Presence detected. Identity inconclusive. Without the Seal of Origin, you may not proceed. Turn back.
USR_403_ELDERS=This sanctum listens not to voice or form… but to resonance of purpose. Yours rings hollow. Access denied.
USR_403_GUARDIAN=Time remembers all who passed… and forgets those who were never meant to enter. You carry no mark, no right. The gate remains closed.
USR_403_OPTIMUS=Optimus talking… Before we proceed… I must know. Are you truly human? Your voice, your soul — reveal your truth.
USR_403_MEGATRON=Bah! Another fleshling? Prove to me you're not some Autobot trick. Speak, or be silenced.
USR_403_GRIMLOCK=You human? Say it loud, or Grimlock smash!
USR_403_OPTIMUS2=I'm sorry… but this path is not meant for humans. The burden of Cybertron is ours to bear.
USR_403_MEGATRON2=Foolish fleshling. You do not belong here. Turn back… or be obliterated.
USR_403_GRIMLOCK2=Grimlock say no humans! You small. You break easy. You go now.
USR_409_ROOT=Already have a super admin!
USR_409_TAKEN=Username is already taken!
USR_412_UNAME=Username is required!
USR_412_PWD=Password is required!
USR_412_NAME=Name is required!
USR_412_LEVEL=Group Access is required!
USR_412_TEAM=Data Domain is required!
PWD_422_LONG=Password must be at least 8 characters long!
PWD_422_ALL=Password must contain at least one uppercase letter, one lowercase letter, one number, and one special character!
PWD_422_UPCASE=Password must contain at least one uppercase letter!
PWD_422_LOCASE=Password must contain at least one lowercase letter!
PWD_422_NUM=Password must contain at least one number!
PWD_422_SPC=Password must contain at least one special character!


# ══════════════════════════════════════════════════════════════════════════════
# [BACKEND — Contract Number Generator]
# Safe to leave as defaults
# ══════════════════════════════════════════════════════════════════════════════

CODE_RANGE=123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz
CODE_LENGTH=13
